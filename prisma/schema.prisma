// ONISTORE — esquema de base de datos
// Producción: Supabase/Postgres. Usa DATABASE_URL para runtime y DIRECT_URL
// para operaciones Prisma como db push/seed contra la conexión directa.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------- Catálogo -----------------------------

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  icon      String? // nombre de icono lucide
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  anime       String? // serie/franquicia (Jujutsu Kaisen, Haikyuu...)
  brand       String? // fabricante (Bandai, Banpresto...)
  sku         String?
  subcategory String? // sub-rubro libre (ej. "Nendoroid", "Tankōbon")

  // SEO por producto (opcional; si vacío se autogenera)
  seoTitle       String?
  seoDescription String?

  // Precios en céntimos de Sol (S/ 89.90 -> 8990)
  priceCents     Int
  discountCents  Int? // precio rebajado opcional

  // NUEVO | SEMINUEVO | USADO | PREORDER
  condition String @default("NUEVO")

  stock      Int     @default(0)
  featured   Boolean @default(false)
  isNew      Boolean @default(false) // bandera "Nuevo ingreso"

  // Zona Chancaditos: items con detalles / outlet
  isChancadito     Boolean @default(false)
  chancaditoReason String? // "Caja con detalle", "Sin blister"...

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images ProductImage[]
  tags   ProductTag[]
  genres ProductGenre[]
  items  OrderItem[]

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([condition])
  @@index([isChancadito])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Tag {
  id       String       @id @default(cuid())
  slug     String       @unique
  name     String
  products ProductTag[]
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

// Géneros / demografías (Shonen, Seinen, Terror, Romance, BL, GL...)
model Genre {
  id       String         @id @default(cuid())
  slug     String         @unique
  name     String
  kind     String         @default("GENERO") // DEMOGRAFIA | GENERO
  order    Int            @default(0)
  products ProductGenre[]
}

model ProductGenre {
  productId String
  genreId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([productId, genreId])
}

// ----------------------------- Hero / Banners -----------------------------

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  ctaText   String?
  ctaHref   String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ----------------------------- Cupones -----------------------------

model Coupon {
  id               String    @id @default(cuid())
  code             String    @unique // siempre en MAYÚSCULAS
  type             String    @default("PERCENT") // PERCENT | FIXED
  value            Int // PERCENT: 1-100 · FIXED: céntimos de Sol
  minSubtotalCents Int       @default(0) // compra mínima para aplicar
  maxUses          Int? // null = ilimitado
  usedCount        Int       @default(0)
  active           Boolean   @default(true)
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
}

// ----------------------------- Pedidos -----------------------------

model Order {
  id   String @id @default(cuid())
  code String @unique // ONI-0001

  customerName String
  phone        String
  email        String?
  address      String?
  district     String? // distrito de entrega

  // Entrega: PICKUP (recojo Arenales) | DELIVERY (envío a domicilio)
  deliveryMethod String @default("PICKUP")

  // Comprobante: BOLETA (DNI) | FACTURA (RUC)
  docType       String  @default("BOLETA")
  docNumber     String? // DNI (8) o RUC (11)
  businessName  String? // razón social (factura)
  fiscalAddress String? // dirección fiscal (factura)

  // WHATSAPP | YAPE | PLIN | CULQI | MERCADOPAGO
  channel String @default("WHATSAPP")
  // PENDIENTE | PAGADO | PREPARANDO | ENVIADO | ENTREGADO | CANCELADO
  status  String @default("PENDIENTE")

  subtotalCents Int
  shippingCents Int     @default(0)
  couponCode    String?
  discountCents Int     @default(0)
  totalCents    Int

  paymentProofUrl String? // comprobante Yape/Plin subido
  note            String?

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  name       String // snapshot del nombre
  priceCents Int
  qty        Int

  @@index([orderId])
}

// ----------------------------- Comunicaciones -----------------------------

model Message {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  subject   String?
  body      String
  // NUEVO | LEIDO | RESPONDIDO
  status    String   @default("NUEVO")
  createdAt DateTime @default(now())

  @@index([status])
}

// ----------------------------- Admin -----------------------------

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}
